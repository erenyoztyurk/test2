---
interface Props {
  label: string;
  value: string;
  change: string;
  trend: 'up' | 'down' | 'neutral';
  color: 'blue' | 'indigo' | 'emerald' | 'amber' | 'rose';
}

const { label, value, change, trend, color } = Astro.props;

const colorMap = {
  blue: {
    bg: "bg-blue-500",
    text: "text-blue-600",
    light: "bg-blue-50"
  },
  indigo: {
    bg: "bg-indigo-500",
    text: "text-indigo-600",
    light: "bg-indigo-50"
  },
  emerald: {
    bg: "bg-emerald-500",
    text: "text-emerald-600",
    light: "bg-emerald-50"
  },
  amber: {
    bg: "bg-amber-500",
    text: "text-amber-600",
    light: "bg-amber-50"
  },
  rose: {
    bg: "bg-rose-500",
    text: "text-rose-600",
    light: "bg-rose-50"
  }
};

const trendStyles = {
  up: "bg-emerald-100 text-emerald-700",
  down: "bg-rose-100 text-rose-700",
  neutral: "bg-slate-100 text-slate-700"
};

const selectedColor = colorMap[color] || colorMap.indigo;
---

<div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all duration-300 group">
  <div class="flex items-center justify-between mb-4">
    <span class="text-sm font-bold text-slate-500 tracking-tight uppercase">{label}</span>
    <div class:list={["flex items-center text-xs px-2 py-1 rounded-full font-bold", trendStyles[trend]]}>
      {trend === 'up' && (
        <svg class="w-3 h-3 mr-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
      )}
      {trend === 'down' && (
        <svg class="w-3 h-3 mr-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
      )}
      {change}
    </div>
  </div>
  
  <div class="flex items-end justify-between">
    <div>
      <div class="text-3xl font-black text-slate-900 tracking-tighter">{value}</div>
    </div>
    <div class:list={["w-10 h-10 rounded-xl flex items-center justify-center transition-colors", selectedColor.light]}>
        <svg class:list={["w-6 h-6", selectedColor.text]} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
        </svg>
    </div>
  </div>

  <div class="h-1.5 w-full bg-slate-100 mt-6 rounded-full overflow-hidden">
    <div 
      class:list={["h-full transition-all duration-1000 ease-out rounded-full", selectedColor.bg]}
      style="width: 70%"
    ></div>
  </div>
</div> 
