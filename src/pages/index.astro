---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <title>Senior Dev Engine | Giriş</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-950 min-h-screen flex items-center justify-center font-['Inter']">
    <div class="max-w-md w-full p-8 bg-slate-900 rounded-[2.5rem] border border-white/10 shadow-2xl">
        <h1 class="text-4xl font-black text-white text-center mb-8 italic">ENGINE <span class="text-indigo-500">V1</span></h1>
        <form class="space-y-4" onsubmit="event.preventDefault(); window.location.href='/admin/dashboard'">
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2 ml-1">Kullanıcı</label>
                <input type="text" id="user" value="admin" class="w-full bg-slate-950 border border-slate-800 rounded-2xl px-5 py-4 text-white outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-2 ml-1">Şifre</label>
                <input type="password" id="pass" value="admin" class="w-full bg-slate-950 border border-slate-800 rounded-2xl px-5 py-4 text-white outline-none focus:ring-2 focus:ring-indigo-500">
            </div>
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-black py-5 rounded-2xl transition-all shadow-lg shadow-indigo-600/20">
                SİSTEME BAĞLAN
            </button>
        </form>
    </div>
</body>
</html>