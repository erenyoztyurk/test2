---
import MainLayout from '../layouts/MainLayout.astro';
const posts = import.meta.glob('./*.md', { eager: true });
const allPosts = Object.values(posts).sort((a, b) => 
    new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<MainLayout title="Platform" description="Advanced AI Technical Analysis">
    
    <section style="padding: 140px 4% 60px; max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 60px;">
        <!-- Sol Hero -->
        <div>
            <span style="color: var(--accent); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">Mühendislik Odaklı Yayıncılık</span>
            <h1 style="font-size: 4.5rem; line-height: 1; font-weight: 900; margin: 20px 0;">Teknolojinin Mimarisini <br/><span style="color: var(--accent);">Analiz Ediyoruz.</span></h1>
            <p style="color: var(--text-secondary); font-size: 1.2rem; max-width: 600px;">Karmaşık algoritmaları, ölçeklenebilir sistemleri ve yapay zeka dönüşümünü derinlemesine inceleyen profesyonel teknik kaynak.</p>
            
            <div class="stats-grid">
                <div class="stat-item"><h3>45k+</h3><p>Aylık Okuyucu</p></div>
                <div class="stat-item"><h3>1.2k+</h3><p>Teknik Makale</p></div>
                <div class="stat-item"><h3>%94</h3><p>Mühendis Memnuniyeti</p></div>
            </div>
        </div>

        <!-- Sağ Topluluk Widget -->
        <div class="glass-card" style="height: fit-content; align-self: center;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h4 style="font-size: 1.1rem;">Topluluk Verileri</h4>
                <div style="width: 10px; height: 10px; background: var(--accent-glow); border-radius: 50%; box-shadow: 0 0 10px var(--accent-glow);"></div>
            </div>
            <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 20px;">Şu an <strong>142</strong> uzman <strong>"LLM Optimizasyonu"</strong> üzerine teknik tartışma yürütüyor.</p>
            <div style="display: flex; gap: 10px;">
                <span style="background: rgba(255,255,255,0.05); padding: 4px 12px; border-radius: 100px; font-size: 0.7rem; border: 1px solid var(--border);">Verified</span>
                <span style="background: rgba(255,255,255,0.05); padding: 4px 12px; border-radius: 100px; font-size: 0.7rem; border: 1px solid var(--border);">Peer Reviewed</span>
            </div>
        </div>
    </section>

    <div style="max-width: 1400px; margin: 0 auto; padding: 0 4% 100px; display: grid; grid-template-columns: 2fr 1fr; gap: 50px;">
        <!-- Sol: Makaleler -->
        <div>
            <span style="display: block; margin-bottom: 30px; font-weight: 700; color: var(--accent);">ÖNE ÇIKAN ANALİZLER</span>
            {allPosts.map(post => (
                <article class="glass-card" style="margin-bottom: 30px; padding: 40px;">
                    <div style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 15px;">{post.frontmatter.date} • 12 Dakika Okuma</div>
                    <h2 style="font-size: 2rem; margin-bottom: 20px;"><a href={post.url} style="color: inherit; text-decoration: none;">{post.frontmatter.title}</a></h2>
                    <p style="color: var(--text-secondary); margin-bottom: 25px;">{post.frontmatter.description}</p>
                    <a href={post.url} style="color: var(--accent); text-decoration: none; font-weight: 700; font-size: 0.9rem;">Analizi Oku →</a>
                </article>
            ))}
        </div>

        <!-- Sağ: Sidebar (Gelişmiş) -->
        <aside style="display: flex; flex-direction: column; gap: 30px;">
            <!-- Forum Arama ve Widget -->
            <div class="glass-card">
                <h4 style="margin-bottom: 20px;">Forum Tartışmaları</h4>
                <input type="text" class="search-box" placeholder="Konu başlığı ara..." />
                <div class="forum-item">
                    <a href="#">C++ 26 ve Bellek Güvenliği Paradigmaları</a>
                    <span>24 Yanıt • 1.2k Görüntüleme</span>
                </div>
                <div class="forum-item">
                    <a href="#">Mikroservislerde Event-Driven Veri Tutarlılığı</a>
                    <span>18 Yanıt • 850 Görüntüleme</span>
                </div>
                <div class="forum-item">
                    <a href="#">Kubernetes 1.30: Sidecar Container Yenilikleri</a>
                    <span>9 Yanıt • 400 Görüntüleme</span>
                </div>
            </div>

            <!-- Fake Google Review / Sektörel Görüş -->
            <div class="glass-card">
                <h4 style="margin-bottom: 20px;">Sektörel Görüş</h4>
                <div class="testimonial">
                    "Sektördeki en nitelikli teknik analizleri burada buluyorum. Boilerplate içeriklerden uzak, tamamen çözüm odaklı."
                </div>
                <p style="margin-top: 15px; font-weight: 700; font-size: 0.8rem; color: var(--accent);">Ahmet Y. - Senior Software Architect</p>
                <div style="margin-top: 5px; color: #fbbf24; font-size: 0.7rem;">★★★★★</div>
            </div>
        </aside>
    </div>
</MainLayout>