---
import AdminLayout from '../../layouts/AdminLayout.astro';

const systemStatus = {
  dbSize: "240 MB",
  cacheSize: "12 MB",
  lastBackup: "4 saat önce",
  version: "v1.0.4-stable"
};
---

<AdminLayout title="Sistem Ayarları" description="Platform global ayarlarını, güvenliği ve sistem bakımını yönetin.">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-6">
      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <h2 class="text-lg font-bold text-slate-800 mb-6 flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-indigo-500"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1Z"/></svg>
          Genel Yapılandırma
        </h2>
        <div class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Site Adı</label>
              <input type="text" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" value="Senior Dev Engine"/>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Admin E-Posta</label>
              <input type="email" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" value="admin@engine.v1"/>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Varsayılan Dil</label>
              <select class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                <option value="tr">Türkçe</option>
                <option value="en">İngilizce</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-2">Zaman Dilimi</label>
              <select class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                <option value="Europe/Istanbul">Europe/Istanbul (GMT+3)</option>
              </select>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-bold text-slate-800 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-rose-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Güvenlik ve Erişim
          </h2>
          <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-bold rounded">SSL AKTİF</span>
        </div>
        <div class="space-y-4">
          <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50/30">
            <div>
              <p class="text-sm font-bold text-slate-700">İki Faktörlü Doğrulama (2FA)</p>
              <p class="text-xs text-slate-400">Giriş güvenliğini artırmak için Authenticator kullanın.</p>
            </div>
            <div class="w-12 h-6 bg-slate-200 rounded-full relative cursor-pointer"><div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full shadow-sm"></div></div>
          </div>
          <div class="flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-slate-50/30">
            <div>
              <p class="text-sm font-bold text-slate-700">Bakım Modu (Maintenance)</p>
              <p class="text-xs text-slate-400">Siteyi ziyaretçilere kapatıp sadece admin erişimine izin verir.</p>
            </div>
            <div class="w-12 h-6 bg-slate-200 rounded-full relative cursor-pointer"><div class="absolute left-1 top-1 w-4 h-4 bg-white rounded-full shadow-sm"></div></div>
          </div>
        </div>
      </section>
    </div>

    <div class="space-y-6">
      <section class="bg-slate-900 rounded-2xl p-6 text-white shadow-xl">
        <h2 class="text-lg font-bold mb-6 flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-indigo-400"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
          Sistem Durumu
        </h2>
        <div class="space-y-4 font-mono text-xs">
          <div class="flex justify-between border-b border-slate-800 pb-2">
            <span class="text-slate-500">Veritabanı:</span>
            <span class="text-indigo-300">{systemStatus.dbSize}</span>
          </div>
          <div class="flex justify-between border-b border-slate-800 pb-2">
            <span class="text-slate-500">Önbellek:</span>
            <span class="text-indigo-300">{systemStatus.cacheSize}</span>
          </div>
          <div class="flex justify-between border-b border-slate-800 pb-2">
            <span class="text-slate-500">Son Yedek:</span>
            <span class="text-indigo-300">{systemStatus.lastBackup}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-slate-500">Versiyon:</span>
            <span class="text-emerald-400">{systemStatus.version}</span>
          </div>
        </div>
        <div class="mt-8 space-y-3">
          <button class="w-full bg-slate-800 hover:bg-slate-700 py-3 rounded-xl text-xs font-bold transition-all border border-slate-700">
            ÖNBELLEĞİ TEMİZLE
          </button>
          <button class="w-full bg-indigo-600 hover:bg-indigo-500 py-3 rounded-xl text-xs font-bold transition-all shadow-lg shadow-indigo-900/40">
            YEDEKLEME BAŞLAT
          </button>
        </div>
      </section>

      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 border-l-4 border-l-rose-500">
        <h2 class="text-xs font-bold text-rose-500 uppercase mb-4 tracking-widest">Kritik Bölge</h2>
        <p class="text-[11px] text-slate-500 mb-4 leading-relaxed">
          Bu işlemler geri alınamaz. Lütfen işlem yapmadan önce sistem yedeği aldığınızdan emin olun.
        </p>
        <button class="w-full bg-rose-50 hover:bg-rose-100 text-rose-600 py-3 rounded-xl text-xs font-bold transition-all">
          SİSTEMİ SIFIRLA
        </button>
      </section>
    </div>
  </div>
</AdminLayout> 
