---
import AdminLayout from '../../layouts/AdminLayout.astro';

const bots = [
  {
    id: "content-bot",
    name: "Makale Üretim Botu",
    status: "active",
    lastRun: "12 dk önce",
    taskCount: 142,
    type: "AI / GPT-4",
    color: "indigo"
  },
  {
    id: "image-bot",
    name: "Görsel Otomasyon Botu",
    status: "active",
    lastRun: "45 dk önce",
    taskCount: 89,
    type: "DALL-E 3",
    color: "purple"
  },
  {
    id: "forum-bot",
    name: "Forum & Yorum Botu",
    status: "idle",
    lastRun: "3 saat önce",
    taskCount: 1204,
    type: "Automation",
    color: "blue"
  },
  {
    id: "trend-bot",
    name: "Keyword Trend Takipçisi",
    status: "error",
    lastRun: "1 gün önce",
    taskCount: 0,
    type: "Scraper",
    color: "rose"
  }
];
---

<AdminLayout title="Bot Kontrol Merkezi" description="Tüm otomasyon motorlarını tek noktadan izleyin ve yönetin.">
  <div class="grid grid-cols-1 gap-6">
    <div class="flex flex-wrap gap-4 mb-2">
      <button class="px-4 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 transition-colors flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M5 3l14 9-14 9V3z"/></svg>
        Tümünü Başlat
      </button>
      <button class="px-4 py-2 bg-white border border-slate-200 text-slate-700 rounded-lg text-sm font-semibold hover:bg-slate-50 transition-colors flex items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><rect x="6" y="6" width="14" height="14" rx="2"/><path d="M6 18H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2h12c1.1 0 2 .9 2 2v2"/></svg>
        Tümünü Durdur
      </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {bots.map((bot) => (
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 relative overflow-hidden group">
          <div class="flex justify-between items-start mb-6">
            <div class="flex items-center">
              <div class:list={["w-12 h-12 rounded-xl flex items-center justify-center mr-4", `bg-${bot.color}-100 text-${bot.color}-600`]}>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-slate-800 tracking-tight">{bot.name}</h3>
                <span class="text-xs text-slate-400 font-medium uppercase tracking-wider">{bot.type}</span>
              </div>
            </div>
            <div class="flex items-center">
              <span class:list={[
                "flex items-center text-xs font-bold px-2.5 py-1 rounded-full",
                bot.status === "active" ? "bg-emerald-100 text-emerald-700" : 
                bot.status === "error" ? "bg-rose-100 text-rose-700" : "bg-slate-100 text-slate-600"
              ]}>
                <span class:list={["w-1.5 h-1.5 rounded-full mr-1.5", bot.status === "active" ? "bg-emerald-500 animate-pulse" : bot.status === "error" ? "bg-rose-500" : "bg-slate-400"]}></span>
                {bot.status.toUpperCase()}
              </span>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-slate-50 rounded-xl p-3">
              <p class="text-[10px] text-slate-400 uppercase font-bold tracking-tighter mb-1">Son Çalışma</p>
              <p class="text-sm font-semibold text-slate-700">{bot.lastRun}</p>
            </div>
            <div class="bg-slate-50 rounded-xl p-3">
              <p class="text-[10px] text-slate-400 uppercase font-bold tracking-tighter mb-1">Toplam Görev</p>
              <p class="text-sm font-semibold text-slate-700">{bot.taskCount}</p>
            </div>
          </div>

          <div class="flex items-center space-x-2">
            <button class="flex-1 bg-slate-900 text-white py-2 rounded-lg text-xs font-bold hover:bg-slate-800 transition-all active:scale-95">
              KONFİGÜRE ET
            </button>
            <button class="p-2 bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
            </button>
            <button class="p-2 bg-rose-50 text-rose-600 rounded-lg hover:bg-rose-100 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
        <h2 class="font-bold text-slate-800 tracking-tight">Bot Kuyruğu ve Zamanlanmış Görevler</h2>
        <span class="text-xs font-medium text-slate-500">Bekleyen: 12 Görev</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="text-xs uppercase text-slate-400 font-bold border-b border-slate-100">
              <th class="px-6 py-4">Görev ID</th>
              <th class="px-6 py-4">Bot</th>
              <th class="px-6 py-4">Hedef</th>
              <th class="px-6 py-4">Zamanlama</th>
              <th class="px-6 py-4 text-right">İşlem</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            {[1, 2, 3].map((i) => (
              <tr class="hover:bg-slate-50/80 transition-colors">
                <td class="px-6 py-4 text-sm font-mono text-slate-500">#TSK-882{i}</td>
                <td class="px-6 py-4 text-sm font-semibold text-slate-700">Content-Gen-V1</td>
                <td class="px-6 py-4 text-sm text-slate-600">Blog / Teknoloji Kategorisi</td>
                <td class="px-6 py-4 text-sm text-slate-500">Bugün, 14:00</td>
                <td class="px-6 py-4 text-right text-indigo-600 font-bold text-xs cursor-pointer hover:underline">İPTAL ET</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</AdminLayout> 
