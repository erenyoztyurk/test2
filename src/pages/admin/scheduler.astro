---
import AdminLayout from '../../layouts/AdminLayout.astro';

const scheduleData = [
  { id: 1, title: "Yapay Zeka ve Etik", time: "14:30", date: "Bugün", status: "pending", bot: "ContentBot-V1" },
  { id: 2, title: "Python Veri Bilimi Rehberi", time: "18:00", date: "Bugün", status: "pending", bot: "ContentBot-V2" },
  { id: 3, title: "SaaS Girişimcilik Fikirleri", time: "09:00", date: "Yarın", status: "scheduled", bot: "ContentBot-V1" },
  { id: 4, title: "Blockchain ve Gelecek", time: "11:20", date: "15 Mayıs", status: "published", bot: "System-Auto" }
];

const timeSlots = ["08:00", "10:00", "12:00", "14:00", "16:00", "18:00", "20:00"];
---

<AdminLayout title="Zamanlanmış Paylaşım" description="İçeriklerin yayınlanma takvimini ve bot kuyruğunu yönetin.">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
    <div class="lg:col-span-3 space-y-6">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/30">
          <div class="flex items-center space-x-4">
            <button class="p-2 hover:bg-slate-200 rounded-lg transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <h2 class="text-lg font-bold text-slate-800 uppercase tracking-tight">Mayıs 2026</h2>
            <button class="p-2 hover:bg-slate-200 rounded-lg transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
          <button class="bg-indigo-600 text-white px-4 py-2 rounded-xl text-sm font-bold shadow-lg shadow-indigo-200 hover:bg-indigo-700 transition-all">
            Yeni İçerik Planla
          </button>
        </div>

        <div class="p-0 overflow-x-auto">
          <div class="min-w-[800px]">
            <div class="grid grid-cols-8 border-b border-slate-100 bg-slate-50 text-center py-3">
              <div class="text-xs font-bold text-slate-400">Saat</div>
              <div class="text-xs font-bold text-slate-800 italic">Pzt</div>
              <div class="text-xs font-bold text-slate-800 italic">Sal</div>
              <div class="text-xs font-bold text-slate-800 italic">Çar</div>
              <div class="text-xs font-bold text-slate-800 italic">Per</div>
              <div class="text-xs font-bold text-slate-800 italic">Cum</div>
              <div class="text-xs font-bold text-slate-400">Cmt</div>
              <div class="text-xs font-bold text-slate-400">Paz</div>
            </div>
            {timeSlots.map((time) => (
              <div class="grid grid-cols-8 border-b border-slate-50 min-h-[80px]">
                <div class="flex items-center justify-center text-[10px] font-mono text-slate-400 border-r border-slate-50 bg-slate-50/20">{time}</div>
                {[1,2,3,4,5,6,7].map((day) => (
                  <div class="p-1 border-r border-slate-50 hover:bg-indigo-50/30 transition-colors relative group cursor-pointer">
                    {time === "14:00" && day === 1 && (
                      <div class="absolute inset-1 bg-indigo-600 rounded-lg p-2 shadow-sm z-10 overflow-hidden">
                        <p class="text-[9px] text-white font-bold truncate leading-tight">Yapay Zeka...</p>
                        <p class="text-[8px] text-indigo-200 truncate italic">ContentBot-V1</p>
                      </div>
                    )}
                    {time === "18:00" && day === 1 && (
                      <div class="absolute inset-1 bg-emerald-500 rounded-lg p-2 shadow-sm z-10 overflow-hidden">
                        <p class="text-[9px] text-white font-bold truncate leading-tight">Python Veri...</p>
                        <p class="text-[8px] text-emerald-100 truncate italic">V2 Motor</p>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <h2 class="text-sm font-bold text-slate-800 mb-6 uppercase tracking-widest flex items-center">
          <span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>
          Paylaşım Kuyruğu
        </h2>
        <div class="space-y-4">
          {scheduleData.filter(d => d.status !== "published").map((item) => (
            <div class="relative pl-4 border-l-2 border-slate-100">
              <div class="absolute -left-[5px] top-0 w-2 h-2 rounded-full bg-slate-300"></div>
              <p class="text-xs font-bold text-slate-700">{item.title}</p>
              <div class="flex items-center mt-1 text-[10px] text-slate-400 font-medium">
                <span class="mr-2 uppercase tracking-tighter">{item.bot}</span>
                <span>•</span>
                <span class="ml-2 font-mono">{item.date}, {item.time}</span>
              </div>
              <div class="mt-2 flex space-x-2">
                <button class="text-[9px] font-bold text-indigo-600 hover:underline">DÜZENLE</button>
                <button class="text-[9px] font-bold text-rose-500 hover:underline">KALDIR</button>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-slate-900 rounded-2xl p-6 text-white overflow-hidden">
        <h3 class="text-sm font-bold mb-4 uppercase tracking-widest text-indigo-400">Arşiv Özeti</h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-slate-800/50 p-3 rounded-xl border border-slate-700">
            <p class="text-[10px] text-slate-400 font-bold mb-1">YAYINLANAN</p>
            <p class="text-xl font-bold font-mono tracking-tighter">842</p>
          </div>
          <div class="bg-slate-800/50 p-3 rounded-xl border border-slate-700">
            <p class="text-[10px] text-slate-400 font-bold mb-1">TASLAKLAR</p>
            <p class="text-xl font-bold font-mono tracking-tighter">18</p>
          </div>
        </div>
        <div class="mt-6">
            <button class="w-full bg-slate-700 hover:bg-slate-600 py-3 rounded-xl text-xs font-bold transition-colors">
                TAM ARŞİVİ GÖRÜNTÜLE
            </button>
        </div>
      </section>
    </div>
  </div>
</AdminLayout> 
