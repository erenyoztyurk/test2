---
import AdminLayout from '../../layouts/AdminLayout.astro';

const seoHealth = {
  score: 88,
  indexedPages: 1240,
  brokenLinks: 4,
  lastSitemapUpdate: "2 saat önce"
};

const topKeywords = [
  { term: "yapay zeka otomasyon", volume: "12.5K", trend: "+14%" },
  { term: "python bot yapımı", volume: "8.2K", trend: "+5%" },
  { term: "otomatik içerik üretme", volume: "4.1K", trend: "-2%" }
];
---

<AdminLayout title="SEO Kontrol Merkezi" description="Arama motoru optimizasyonu, sitemap ve meta tag yönetimi.">
  <div class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm text-center">
        <p class="text-xs font-bold text-slate-400 uppercase mb-2">SEO Skoru</p>
        <div class="relative inline-flex items-center justify-center">
          <svg class="w-20 h-20">
            <circle class="text-slate-100" stroke-width="8" stroke="currentColor" fill="transparent" r="30" cx="40" cy="40"/>
            <circle class="text-indigo-600" stroke-width="8" stroke-dasharray="188.4" stroke-dashoffset={188.4 - (188.4 * seoHealth.score) / 100} stroke-linecap="round" stroke="currentColor" fill="transparent" r="30" cx="40" cy="40"/>
          </svg>
          <span class="absolute text-xl font-bold text-slate-800">{seoHealth.score}</span>
        </div>
      </div>
      <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">Index Durumu</p>
        <p class="text-2xl font-bold text-slate-800">{seoHealth.indexedPages}</p>
        <p class="text-xs text-emerald-500 mt-2 font-semibold">↑ %100 Verimlilik</p>
      </div>
      <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">Kırık Linkler</p>
        <p class="text-2xl font-bold text-rose-600">{seoHealth.brokenLinks}</p>
        <button class="text-[10px] text-indigo-600 font-bold underline mt-2">TARAMAYI BAŞLAT</button>
      </div>
      <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">Sitemap</p>
        <p class="text-sm font-semibold text-slate-700">{seoHealth.lastSitemapUpdate}</p>
        <p class="text-[10px] text-slate-400 mt-2 italic">Dinamik XML Aktif</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
          <h2 class="font-bold text-slate-800 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-indigo-500"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15h6"/><path d="M9 11h6"/><path d="M9 19h1"/></svg>
            Robots.txt Editörü
          </h2>
          <button class="bg-slate-900 text-white px-3 py-1.5 rounded-lg text-xs font-bold">KAYDET</button>
        </div>
        <div class="p-4 bg-slate-50 font-mono text-xs text-slate-600 min-h-[200px] outline-none" contenteditable="true">
          User-agent: *<br/>
          Allow: /<br/>
          Disallow: /admin/<br/>
          Disallow: /api/<br/><br/>
          Sitemap: https://domain.com/sitemap.xml
        </div>
      </section>

      <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
        <h2 class="font-bold text-slate-800 mb-6 flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-indigo-500"><path d="M21 12V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h7"/><path d="M16 5V3"/><path d="M8 5V3"/><path d="M3 9h16"/><path d="M21 21.35 18.35 18.7"/><circle cx="15.5" cy="15.85" r="3.5"/></svg>
          Keyword Trend Takipçisi
        </h2>
        <div class="space-y-4">
          {topKeywords.map((kw) => (
            <div class="flex items-center justify-between p-3 rounded-xl border border-slate-50 bg-slate-50/50">
              <div class="flex flex-col">
                <span class="text-sm font-bold text-slate-700">{kw.term}</span>
                <span class="text-[10px] text-slate-400 tracking-wider">Aylık Hacim: {kw.volume}</span>
              </div>
              <div class:list={[
                "text-xs font-bold px-2 py-1 rounded-lg",
                kw.trend.startsWith('+') ? "bg-emerald-100 text-emerald-700" : "bg-rose-100 text-rose-700"
              ]}>
                {kw.trend}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>

    <section class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="p-6 border-b border-slate-100">
        <h2 class="font-bold text-slate-800">Global Meta Tag Yönetimi</h2>
      </div>
      <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase mb-2 tracking-tighter">Site Ana Başlığı</label>
            <input type="text" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm" value="Senior Dev Engine - AI Automation Platform"/>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase mb-2 tracking-tighter">Site Açıklaması (Description)</label>
            <textarea rows="3" class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-sm">Yapay zeka destekli içerik üretimi ve SEO otomasyonu için tek durak çözüm merkezi.</textarea>
          </div>
        </div>
        <div class="space-y-4 bg-slate-900 rounded-2xl p-5 text-white">
          <h3 class="text-xs font-bold text-indigo-400 uppercase tracking-widest mb-4">Google Önizleme</h3>
          <div class="space-y-1">
            <p class="text-indigo-400 text-xs truncate">https://domain.com</p>
            <p class="text-blue-400 text-lg leading-tight hover:underline cursor-pointer">Senior Dev Engine - AI Automation Platform</p>
            <p class="text-slate-400 text-xs leading-relaxed line-clamp-2">Yapay zeka destekli içerik üretimi ve SEO otomasyonu için tek durak çözüm merkezi...</p>
          </div>
        </div>
      </div>
    </section>
  </div>
</AdminLayout> 
